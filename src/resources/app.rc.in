#include <winver.h>

#define LATEXAPP_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define LATEXAPP_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define LATEXAPP_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define LATEXAPP_VERSION_BUILD 0

VS_VERSION_INFO VERSIONINFO
 FILEVERSION LATEXAPP_VERSION_MAJOR,LATEXAPP_VERSION_MINOR,LATEXAPP_VERSION_PATCH,LATEXAPP_VERSION_BUILD
 PRODUCTVERSION LATEXAPP_VERSION_MAJOR,LATEXAPP_VERSION_MINOR,LATEXAPP_VERSION_PATCH,LATEXAPP_VERSION_BUILD
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "LaTeXApp"
            VALUE "FileDescription", "Windows desktop LaTeX editor"
            VALUE "FileVersion", "@PROJECT_VERSION@.0"
            VALUE "InternalName", "LaTeXApp"
            VALUE "OriginalFilename", "LaTeXApp.exe"
            VALUE "ProductName", "LaTeXApp"
            VALUE "ProductVersion", "@PROJECT_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
